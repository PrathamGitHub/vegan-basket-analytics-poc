GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/service-account.json

DUCKDB_PATH=./data/vegan_basket.duckdb
DLT_PIPELINE_NAME=vegan_basket
DLT_DATASET_NAME=raw

# --- Daily ingestion options ---

# Path where the revision guard stores row counts from the last successful run.
# If the sheet row counts are unchanged since last run, the pipeline skips the
# dlt load entirely. File is created automatically on first run.
# Default: ./data/ingest_state.json
# INGEST_STATE_PATH=./data/ingest_state.json

# Set to true to bypass the revision guard and always run the full pipeline.
# Useful after a dbt model change or to force a reload on demand.
# Default: false
# FORCE_RUN=false

# --- Telegram daily digest ---

# Create a bot via @BotFather and DM it once before first use.
# See deploy/telegram/README.md for full client + server setup steps.
TELEGRAM_BOT_TOKEN=

# Option A — Group chat (recommended for 2-3 people): add the bot to a private
# group, then paste the group's negative chat ID here.  Add/remove recipients by
# adding/removing members in the Telegram app — no server change ever needed.
TELEGRAM_CHAT_ID=

# Option B — Individual DMs (fallback): comma-separated list of personal chat IDs.
# If both variables are set they are merged and deduplicated automatically.
# TELEGRAM_CHAT_IDS=111111111,222222222,333333333

# Set to false to disable the digest without removing tokens.
# TELEGRAM_DIGEST_ENABLED=true
